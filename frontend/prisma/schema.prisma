generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TRAINER
  CLIENT
}

enum LessonStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id               String            @id @default(uuid())
  role             Role              @default(CLIENT)
  phone            String            @unique
  email            String            @unique
  name             String
  templates        ScheduleTemplate[]
  actualLessons    ActualLesson[]
  bookings         Booking[]
}

model ScheduleTemplate {
  id               String            @id @default(uuid())
  trainer_id       String
  trainer          User              @relation(fields: [trainer_id], references: [id])
  day_of_week      Int               // 0-6 (0 = Sunday)
  start_time       String            // e.g. "10:00"
  end_time         String            // e.g. "11:00"
  class_name       String
  capacity         Int
  actualLessons    ActualLesson[]
}

model ActualLesson {
  id               String            @id @default(uuid())
  template_id      String?
  template         ScheduleTemplate? @relation(fields: [template_id], references: [id])
  trainer_id       String
  trainer          User              @relation(fields: [trainer_id], references: [id])
  start_timestamp  DateTime
  end_timestamp    DateTime
  class_name       String
  capacity         Int
  status           LessonStatus      @default(SCHEDULED)
  bookings         Booking[]

  @@index([start_timestamp, status])
}

model Booking {
  id               String            @id @default(uuid())
  lesson_id        String
  lesson           ActualLesson      @relation(fields: [lesson_id], references: [id])
  client_id        String
  client           User              @relation(fields: [client_id], references: [id])
  status           BookingStatus     @default(PENDING_PAYMENT)
  created_at       DateTime          @default(now())
  payment          Payment?
}

model Payment {
  id               String            @id @default(uuid())
  booking_id       String            @unique
  booking          Booking           @relation(fields: [booking_id], references: [id])
  mono_invoice_id  String            @unique
  amount           Decimal           @db.Decimal(10, 2)
  status           PaymentStatus     @default(CREATED)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
}

// ── Studio app (shared schedule, bookings, CRM) — used by Express API + frontend ──

model PublicLesson {
  id                 String                @id
  class_name         String
  trainer_name       String
  start_timestamp    DateTime
  end_timestamp      DateTime
  capacity           Int
  booked_count       Int                   @default(0)
  status             String                @default("SCHEDULED")
  single_visit_price Int                   @default(300)
  bookings           PublicLessonBooking[]

  @@index([start_timestamp])
  @@map("public_lesson")
}

model PublicLessonBooking {
  id             String          @id @default(cuid())
  lesson_id      String
  lesson         PublicLesson    @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  client_user_id String?
  client_email   String
  client_name    String
  /// PENDING_PAYMENT | CONFIRMED | CANCELLED | REFUNDED — stored as string to match the migration.
  status         String          @default("CONFIRMED")
  created_at     DateTime        @default(now())
  meta           Json?
  payments       StudioPayment[]

  @@index([lesson_id])
  @@index([client_email])
  @@index([status, created_at])
  @@map("public_lesson_booking")
}

model StudioPayment {
  id                String               @id
  liqpay_order_id   String               @unique
  liqpay_payment_id String?
  amount            Int
  currency          String               @default("UAH")
  /// CREATED | SUCCESS | FAILED | REFUNDED
  status            String               @default("CREATED")
  /// 'single_visit' | 'plan_purchase'
  purpose           String
  booking_id        String?
  booking           PublicLessonBooking? @relation(fields: [booking_id], references: [id], onDelete: SetNull)
  client_user_id    String?
  client_email      String
  plan_id           String?
  /// Canonical plan as it existed at payment time — used to grant the subscription on success.
  plan_snapshot     Json?
  meta              Json?
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt
  paid_at           DateTime?
  refunded_at       DateTime?

  @@index([client_email])
  @@index([booking_id])
  @@index([status])
  @@map("studio_payment")
}

model StudioClient {
  id                  String @id
  email               String @unique
  name                String
  phone               String @default("")
  subscriptions_json  Json   @default("[]")

  @@map("studio_client")
}

model StudioConfig {
  id               Int  @id @default(1)
  trainers_json    Json
  class_types_json Json
  plans_json       Json
  promo_codes_json Json

  @@map("studio_config")
}
